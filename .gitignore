# Create .gitignore file
cat > .gitignore << 'EOF'
# Secrets and credentials (CRITICAL)
*.json
*credentials.json
*token.json
*.key
*.pem
*.p12
*.pfx
.env
.env.local
.env.*.local
*.secret
secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
pythonenv*
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
.venv/
.venv_*/
venv/
virtualenv/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.desktop.ini
Thumbs.db
*.sublime-*
.project
.classpath

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Logs and databases
*.log
*.sql
*.sqlite3
*.db
logs/
log/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
*.cover

# Environment variables
.env
.env.*
!.env.example

# Application specific
backend/app/ingestion/token.json
backend/app/ingestion/credentials.json
backend/app/ingestion/*.json
!backend/app/ingestion/sample.json
!backend/app/ingestion/schema.json

# Uploads and user data
uploads/
downloads/
temp/
tmp/
media/
staticfiles/

# Docker
*.pid
docker-compose.override.yml
.dockerignore
Dockerfile.*
!Dockerfile

# OS specific
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
Desktop.ini

# Backup files
*.bak
*.backup
*.old
*.orig

# Documentation build
docs/_build/
site/

# Node modules (if you have any frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
EOF